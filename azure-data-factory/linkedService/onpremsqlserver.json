{
	"name": "onpremsqlserver",
	"type": "Microsoft.DataFactory/factories/linkedservices",
	"properties": {
		"annotations": [],
		"parameters": {
			"serverName": {
				"type": "String",
				"defaultValue": "localhost\\SQLEXPRESS"
			},
			"databaseName": {
				"type": "String",
				"defaultValue": "AdventureWorksLT2022"
			},
			"userName": {
				"type": "String",
				"defaultValue": "Vikram_kavuri"
			}
		},
		"type": "SqlServer",
		"typeProperties": {
			"server": "@{linkedService().serverName}",
			"database": "@{linkedService().databaseName}",
			"encrypt": "optional",
			"trustServerCertificate": false,
			"authenticationType": "SQL",
			"userName": "@{linkedService().userName}",
			"password": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "keyvault_e2e_de",
					"type": "LinkedServiceReference"
				},
				"secretName": "localdb-password"
			}
		},
		"connectVia": {
			"referenceName": "SelfHostedIntegrationRuntime",
			"type": "IntegrationRuntimeReference"
		}
	}
}
