{
	"name": "AzureDatabricks1",
	"type": "Microsoft.DataFactory/factories/linkedservices",
	"properties": {
		"annotations": [],
		"parameters": {
			"databricksWorkspaceUrl": {
				"type": "String",
				"defaultValue": "https://<your-databricks-workspace-url>"
			},
			"existingClusterId": {
				"type": "String",
				"defaultValue": "<your-cluster-id>"
			}
		},
		"type": "AzureDatabricks",
		"typeProperties": {
			"domain": "@{linkedService().databricksWorkspaceUrl}",
			"accessToken": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "keyvault_e2e_de",
					"type": "LinkedServiceReference"
				},
				"secretName": "dbwtoken"
			},
			"existingClusterId": "@{linkedService().existingClusterId}"
		}
	}
}
